# Берем официальный легкий образ Node.js
FROM node:20-alpine

# Задаем рабочую папку внутри контейнера
WORKDIR /app

# Копируем настройки пакетов
COPY package*.json ./

# Устанавливаем модули (скачается папка node_modules)
RUN npm install

# Копируем все ваши компоненты React и ассеты в контейнер
COPY . .

# Открываем стандартный порт Vite наружу
EXPOSE 5173

# Запускаем локальный сервер разработки Vite с флагом --host,
# чтобы он выпускал трафик наружу из контейнера в ваш браузер
CMD ["npm", "run", "dev", "--", "--host"]
